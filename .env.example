# QuickBooks Online API
QBO_CLIENT_ID=your_client_id_here
QBO_CLIENT_SECRET=your_client_secret_here
QBO_REDIRECT_URI=http://localhost:5000/qbo/callback
QBO_ENVIRONMENT=sandbox
QBO_COMPANY_ID=

# Email (IMAP)
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FOLDER=INBOX
EMAIL_POLL_INTERVAL_SECONDS=60

# Application
APP_SECRET_KEY=change-this-to-a-random-string
DATABASE_PATH=data/app.db
XML_STORAGE_PATH=data/xml_files
LOG_LEVEL=INFO

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
